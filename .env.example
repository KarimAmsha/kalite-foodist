# ---------------------------------------------------------------------------
# Kalite Çikolata - Foodist Istanbul 2026 Microsite
# Copy this file to `.env.local` and fill in the real values.
# Never commit `.env.local`. Keep webhook URLs out of client code.
# ---------------------------------------------------------------------------

# Public site URL (used for canonical tags, OpenGraph, sitemaps)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# WhatsApp number in international format WITHOUT '+' or spaces
# (placeholder for now — set the real number before launch)
NEXT_PUBLIC_WHATSAPP_NUMBER=900000000000

# Default locale when none is detected
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Google Apps Script Web App URL that receives the lead and writes to Sheets.
# This is SERVER-ONLY (used by /api/lead). Do NOT prefix with NEXT_PUBLIC_.
GOOGLE_SCRIPT_WEBHOOK_URL=https://script.google.com/macros/s/xxxx/exec

# Public Google Form fallback link (shown if the webhook is unavailable)
NEXT_PUBLIC_GOOGLE_FORM_FALLBACK_URL=https://forms.gle/xxxx

# Catalogue links. Defaults point to the official Google Drive files
# (see src/content/catalogues.ts). Override here only if the files move.
NEXT_PUBLIC_CATALOGUE_NUKKA_URL=https://drive.google.com/file/d/1SrRcyhYtdZOvoSs-v1DV-3v-C5J6n-6b/view
NEXT_PUBLIC_CATALOGUE_PROSWEET_URL=https://drive.google.com/file/d/1YkSYI1-OYqVahl7Jj4AJCaAKYTurZfnM/view
NEXT_PUBLIC_CATALOGUE_JELLYFUNNY_URL=https://drive.google.com/file/d/1eTeSdxj3gf7IT1UzRXZWtI0ABlhTSTuX/view
NEXT_PUBLIC_CATALOGUE_NEW_PRODUCTS_URL=https://drive.google.com/file/d/1injOwb1X36d4fRBKabsjMm0un3N2iZ6R/view
